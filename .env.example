# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Auth
# Password for the creator login (username is hardcoded as "admin")
CREATOR_PASSWORD=your-password-here

# Secret used to sign session cookies — generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here
